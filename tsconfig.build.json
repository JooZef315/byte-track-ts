{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "target": "ES2020",
    "allowImportingTsExtensions": false
  },
  "include": ["src"]
}
